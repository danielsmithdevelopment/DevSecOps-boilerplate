# Copy to .env before: docker compose up -d
# From repo root: docker compose -f docker/observability/docker-compose.yaml --env-file docker/observability/.env up -d

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme-grafana-admin

# OnCall (profile: oncall)
ONCALL_SECRET_KEY=dev-oncall-secret-key-min-32-chars-long
ONCALL_BASE_URL=http://localhost:8090

# Beyla eBPF auto-instrumentation
BEYLA_OPEN_PORT=8080
